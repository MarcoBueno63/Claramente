// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  locale           String   @default("pt-BR")
  ageConfirmed     Boolean  @default(false)
  freeSessionsUsed Int      @default(0)
  createdAt        DateTime @default(now())
  
  // Perfil terapêutico
  therapeuticProfile Json?   // Preferências e histórico
  riskProfile        String  @default("low") // low|medium|high|crisis
  primaryConcerns    String[] @default([])
  therapeuticGoals   String[] @default([])
  preferredTechniques String[] @default([])
  
  // Relacionamentos
  sessions         Session[]
  payments         Payment[]
  leads            Lead[] @relation("UserLeads")
  progressReports  ProgressReport[]
  psychometricAssessments PsychometricAssessment[]
  userStatistics   UserStatistics?
}

model Session {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  durationMin         Int       @default(0)
  language            String    @default("pt-BR")
  persona             String
  style               String
  status              String    @default("active") // active|ended
  riskFlag            String    @default("none")
  summary             String?
  
  // Dados terapêuticos
  detectedEmotions    String[]  @default([])
  appliedTechniques   String[]  @default([])
  conversationStage   String    @default("greeting") // greeting|exploration|deepening|intervention|closure
  userSymptoms        String[]  @default([])
  suggestedProtocols  String[]  @default([])
  urgencyLevel        String    @default("low") // low|medium|high|crisis
  primaryConcern      String?
  therapeuticGoals    String[]  @default([])
  
  messages            Message[]
  assessments         Assessment[]
  exercises           TherapeuticExercise[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  role      String   // user|assistant|system
  content   String
  technique String?  // Técnica TCC/DBT/ACT aplicada
  intervention String? // Intervenção específica
  emotionalTone String? // positive|negative|neutral|mixed
  urgencyLevel String? // low|medium|high|crisis
  createdAt DateTime @default(now())
}

// Tabela para avaliações psicométricas
model Assessment {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  type        String   // beck_depression|beck_anxiety|gad7|phq9|etc
  questions   Json     // Perguntas e respostas
  score       Int
  severity    String   // minimal|mild|moderate|severe
  createdAt   DateTime @default(now())
}

// Tabela para exercícios terapêuticos
model TherapeuticExercise {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  exerciseId  String   // ID do exercício da biblioteca
  name        String
  category    String   // cognitive|behavioral|mindfulness|exposure|etc
  difficulty  String   // basic|intermediate|advanced
  status      String   // prescribed|started|completed|skipped
  results     Json?    // Resultados e respostas
  timeSpent   Int?     // Tempo gasto em minutos
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  sessionId   String?
  status      String   // pending|paid|failed
  providerRef String?
  createdAt   DateTime @default(now())
}

model Psychologist {
  id          String   @id @default(cuid())
  name        String
  crp         String
  specialty   String
  approach    String
  gender      String
  location    String
  price       Int
  whatsapp    String
  rating      Float
  experience  Int
  leads       Lead[] @relation("PsychologistLeads")
}

model Lead {
  id             String   @id @default(cuid())
  userId         String
  user           User @relation("UserLeads", fields: [userId], references: [id])
  psychologistId String
  psychologist   Psychologist @relation("PsychologistLeads", fields: [psychologistId], references: [id])
  status         String   // new|contacted|scheduled|paid
  createdAt      DateTime @default(now())
}

// Tabela para relatórios de progresso
model ProgressReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String   // weekly|monthly|milestone
  period          String   // "2025-11-W1"|"2025-11"|"milestone_1"
  metrics         Json     // Métricas calculadas
  insights        String[] // Insights automáticos
  recommendations String[] // Recomendações
  createdAt       DateTime @default(now())
}

// Modelo para avaliações psicométricas completas
model PsychometricAssessment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  overallRiskLevel  String   // low|medium|high|critical
  primaryConcerns   String[] // Áreas de preocupação identificadas
  recommendations   String[] // Recomendações gerais
  urgentAction      Boolean  @default(false) // Se requer ação urgente
  completedAt       DateTime @default(now())
  
  // Relacionamentos
  scaleResults      PsychometricScaleResult[]
}

// Modelo para resultados individuais das escalas
model PsychometricScaleResult {
  id                      String   @id @default(cuid())
  psychometricAssessmentId String
  psychometricAssessment  PsychometricAssessment @relation(fields: [psychometricAssessmentId], references: [id])
  scaleId                 String   // bdi_ii|bai|gad7|phq9|etc
  scaleName               String   // Nome da escala
  score                   Int      // Score total
  interpretation          String   // Interpretação textual
  riskLevel              String   // Nível de risco específico desta escala
  recommendations        String[] // Recomendações específicas
  rawResponses           Json?    // Respostas brutas para auditoria
  createdAt              DateTime @default(now())
}

// Modelo para estatísticas do usuário
model UserStatistics {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id])
  
  // Estatísticas de sessão
  totalSessions          Int      @default(0)
  totalAssessments       Int      @default(0)
  averageSessionDuration Int      @default(0) // em minutos
  
  // Histórico de melhoria
  lastAssessmentDate     DateTime?
  riskLevelHistory       String[] @default([]) // Histórico de níveis de risco
  improvementScore       Int      @default(0)  // Score de melhoria (-100 a +100)
  
  // Métricas terapêuticas
  appliedTechniques      String[] @default([]) // Técnicas mais aplicadas
  primaryEmotions        String[] @default([]) // Emoções mais frequentes
  progressMilestones     Json[]   @default([]) // Marcos de progresso
  
  updatedAt              DateTime @updatedAt
}
